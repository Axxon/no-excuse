APP_NAME=no-excuse
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:18080

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12
NO_EXCUSE_TOKEN_LIFETIME_HOURS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=no_excuse
DB_USERNAME=no_excuse
DB_PASSWORD=no_excuse

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=240

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="notifications@no-excuse.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# "demo" fonctionne sans clé et rend les décisions explicables.
# "live" envoie le texte des CV aux fournisseurs sélectionnés par le recruteur.
NO_EXCUSE_AI_MODE=demo
NO_EXCUSE_SCOPE_THRESHOLD=25
NO_EXCUSE_PUBLIC_DEMO=false
NO_EXCUSE_DEMO_LIFETIME_HOURS=4
NO_EXCUSE_DEMO_MAX_SESSIONS=20
NO_EXCUSE_DEMO_PROCESSING_DELAY_SECONDS=2
NO_EXCUSE_DEMO_SCREENING_WORKERS=2
NO_EXCUSE_DEMO_SCORING_WORKERS=1
NO_EXCUSE_REJECTED_CV_RETENTION_DAYS=0
NO_EXCUSE_SELECTED_CV_RETENTION_DAYS=90
NO_EXCUSE_CANDIDATE_DATA_RETENTION_DAYS=730
NO_EXCUSE_WAITLIST_RETENTION_DAYS=30
NO_EXCUSE_AUTHOR_NAME="Project author"
NO_EXCUSE_AUTHOR_LINKEDIN_URL=

OPENAI_API_KEY=
OPENAI_STORE=false
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434
OPENAI_COMPATIBLE_URL=
OPENAI_COMPATIBLE_API_KEY=
